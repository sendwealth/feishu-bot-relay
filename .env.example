# 飞书机器人消息中转系统 - 环境变量配置

# 服务配置
PORT=3000
NODE_ENV=development

# 飞书应用配置（示例）
# 可以注册多个机器人，用逗号分隔
BOT_APP_IDS=cli_aabbccdd,cli_bbccdd
BOT_APP_SECRETS=secret1,secret2

# 数据库配置（MVP版本使用内存存储，可选）
# MONGODB_URI=mongodb://localhost:27017/feishu-relay

# Redis配置（可选，用于缓存）
# REDIS_URL=redis://localhost:6379

# 消息队列配置（可选，用于异步处理）
# RABBITMQ_URL=amqp://localhost:5672

# 安全配置
JWT_SECRET=your-jwt-secret-change-this
WEBHOOK_SECRET=your-webhook-secret-change-this

# 日志配置
LOG_LEVEL=info
LOG_FILE=logs/relay.log

# 限流配置
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=100

# 循环检测配置
MAX_RELAY_COUNT=3
